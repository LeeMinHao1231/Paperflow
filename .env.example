# Public OAuth client ID. This value is safe to expose in the browser.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google client secrets are intentionally not used by this browser-based OAuth flow.

# Free OCR runs in a local Python service. No API key is required.
PADDLEOCR_SERVICE_URL=http://127.0.0.1:8765

# Installed local model. The larger PP-OCRv5_server_rec model can improve
# handwriting but is much slower on CPU.
PADDLEOCR_RECOGNITION_MODEL=en_PP-OCRv5_mobile_rec

# Optional high-accuracy cloud reader. Keep this server-only: never add NEXT_PUBLIC_.
OPENAI_API_KEY=your-openai-project-api-key
OPENAI_VISION_MODEL=gpt-5.6-luna
